{
  "info": {
    "_postman_id": "5fd6c3e0-d1b0-4e9f-975d-64d9e56f7bc0",
    "name": "Automated Talent API (MVP)",
    "description": "Simple authenticated collection for the Django MVP API. Includes ready-to-run Zoho Forms payload examples.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Start Job",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"HVAC Technician\",\n  \"location\": \"Phoenix\",\n  \"keywords\": \"HVAC, maintenance, service\",\n  \"job_type\": \"direct\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/start-job/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "start-job",
            ""
          ]
        },
        "description": "Creates a job and returns `job_id`."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Start Job returns 201\", function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "if (jsonData.job_id) {",
              "  pm.environment.set(\"jobId\", jsonData.job_id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Run Job",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"job_id\": \"{{jobId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/run-job/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "run-job",
            ""
          ]
        },
        "description": "Runs the search/extract/score pipeline for the saved `jobId`."
      }
    },
    {
      "name": "Job Status",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/job-status/{{jobId}}/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "job-status",
            "{{jobId}}",
            ""
          ]
        },
        "description": "Checks job progress/result counts."
      }
    },
    {
      "name": "Zoho Forms Payload Examples",
      "item": [
        {
          "name": "Sample JSON webhook body",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Candidate_Role\": \"HVAC Technician\",\n  \"Preferred_Location\": \"Phoenix\",\n  \"Skills_Keywords\": \"HVAC, maintenance, service\",\n  \"Employment_Type\": \"direct\",\n  \"Candidate_Name\": \"Alex Carter\",\n  \"Email\": \"alex.carter@example.com\",\n  \"Submission_ID\": \"ZF-10021\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/start-job/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "start-job",
                ""
              ]
            },
            "description": "Example of a Zoho Forms-style payload if your webhook sends JSON."
          }
        },
        {
          "name": "Mapped payload to Start Job schema",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"{{zohoRole}}\",\n  \"location\": \"{{zohoLocation}}\",\n  \"keywords\": \"{{zohoKeywords}}\",\n  \"job_type\": \"{{zohoJobType}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/start-job/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "start-job",
                ""
              ]
            },
            "description": "Direct payload shape expected by this MVP API. Use these fields in Zoho Forms webhook mapping."
          }
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{serviceApiKey}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get(\"serviceApiKey\")) {",
          "  console.warn(\"Set serviceApiKey in the Postman environment before sending requests.\");",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "jobId",
      "value": ""
    },
    {
      "key": "zohoRole",
      "value": "HVAC Technician"
    },
    {
      "key": "zohoLocation",
      "value": "Phoenix"
    },
    {
      "key": "zohoKeywords",
      "value": "HVAC, maintenance, service"
    },
    {
      "key": "zohoJobType",
      "value": "direct"
    }
  ]
}
